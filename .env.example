# ── Minimal .env for SQLite + local storage (zero-cost demo) ─────────────────
# Copy to .env and fill in values. All 3 services read from this file.
# DJANGO_SECRET_KEY must be IDENTICAL across all 3 services — it is the JWT signing key.

DJANGO_SECRET_KEY=django-insecure-nus4m=p(jo=bgt8f3#*1&!!3g_#fs(q*33sv769)_!g-qx9z6f
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Service-to-service URLs (share-service calls file-service to verify files exist)
FILE_SERVICE_URL=http://localhost:8002
AUTH_SERVICE_URL=http://localhost:8001

# Frontend API URLs (Next.js reads these at build time)
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8001/api
NEXT_PUBLIC_FILE_API_URL=http://localhost:8002/api
NEXT_PUBLIC_SHARE_API_URL=http://localhost:8003/api
