POSTGRES_USER=<azure-postgres-user>
POSTGRES_PASSWORD=<azure-postgres-password>
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

AUTH_POSTGRES_DB=auth_service
AUTH_POSTGRES_HOST=<your-postgres-server>.postgres.database.azure.com
FILE_POSTGRES_DB=file_service
FILE_POSTGRES_HOST=<your-postgres-server>.postgres.database.azure.com
SHARE_POSTGRES_DB=share_service
SHARE_POSTGRES_HOST=<your-postgres-server>.postgres.database.azure.com

DJANGO_SECRET_KEY=<generate-a-long-random-secret>
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=<auth-app>.azurewebsites.net,<file-app>.azurewebsites.net,<share-app>.azurewebsites.net
CORS_ALLOWED_ORIGINS=https://<frontend-domain>
CSRF_TRUSTED_ORIGINS=https://<frontend-domain>

NEXT_PUBLIC_AUTH_API_URL=https://<auth-app>.azurewebsites.net/api
NEXT_PUBLIC_FILE_API_URL=https://<file-app>.azurewebsites.net/api
NEXT_PUBLIC_SHARE_API_URL=https://<share-app>.azurewebsites.net/api
AUTH_SERVICE_URL=https://<auth-app>.azurewebsites.net
FILE_SERVICE_URL=https://<file-app>.azurewebsites.net
SHARE_SERVICE_URL=https://<share-app>.azurewebsites.net

AZURE_STORAGE_CONNECTION_STRING=<azure-storage-connection-string>
AZURE_STORAGE_CONTAINER=uploads
