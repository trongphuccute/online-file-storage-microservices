# ── Azure deployment environment variables ────────────────────────────────────
# Copy this content into each App Service → Configuration → Application settings
# All 3 services (auth, file, share) must share the same DJANGO_SECRET_KEY
# so JWT tokens issued by auth-service can be verified by file-service and share-service.

# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-nus4m=p(jo=bgt8f3#*1&!!3g_#fs(q*33sv769)_!g-qx9z6f
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=<auth-app>.azurewebsites.net,<file-app>.azurewebsites.net,<share-app>.azurewebsites.net
CORS_ALLOWED_ORIGINS=https://<your-vercel-app>.vercel.app
CSRF_TRUSTED_ORIGINS=https://<your-vercel-app>.vercel.app

# ── PostgreSQL — one Azure Flexible Server, three databases ───────────────────
POSTGRES_USER=<azure-postgres-admin-user>
POSTGRES_PASSWORD=<azure-postgres-password>
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# auth-service reads these two
AUTH_POSTGRES_DB=auth_service
AUTH_POSTGRES_HOST=<your-server>.postgres.database.azure.com

# file-service reads these two
FILE_POSTGRES_DB=file_service
FILE_POSTGRES_HOST=<your-server>.postgres.database.azure.com

# share-service reads these two
SHARE_POSTGRES_DB=share_service
SHARE_POSTGRES_HOST=<your-server>.postgres.database.azure.com

# ── Azure Blob Storage (file-service only) ────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=uploads
MAX_UPLOAD_FILE_BYTES=52428800

# ── Service-to-service URLs ───────────────────────────────────────────────────
AUTH_SERVICE_URL=https://<auth-app>.azurewebsites.net
FILE_SERVICE_URL=https://<file-app>.azurewebsites.net
SHARE_SERVICE_URL=https://<share-app>.azurewebsites.net

# ── Frontend env vars (set these in Vercel, not Azure) ───────────────────────
# NEXT_PUBLIC_AUTH_API_URL=https://<auth-app>.azurewebsites.net/api
# NEXT_PUBLIC_FILE_API_URL=https://<file-app>.azurewebsites.net/api
# NEXT_PUBLIC_SHARE_API_URL=https://<share-app>.azurewebsites.net/api
